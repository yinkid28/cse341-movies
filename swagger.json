{
  "openapi": "3.0.0",
  "info": {
    "title": "Movies & TV Shows API",
    "description": "A RESTful API for managing movies and TV shows",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://cse341-movies-20er.onrender.com",
      "description": "Production server"
    },
    {
      "url": "http://localhost:8080",
      "description": "Local server"
    }
  ],
  "paths": {
    "/movies": {
      "get": {
        "summary": "Get all movies",
        "tags": ["Movies"],
        "responses": {
          "200": { "description": "List of all movies" },
          "500": { "description": "Server error" }
        }
      },
      "post": {
        "summary": "Create a new movie",
        "tags": ["Movies"],
        "security": [{ "GoogleOAuth": ["profile", "email"] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Movie" }
            }
          }
        },
        "responses": {
          "201": { "description": "Movie created successfully" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized - login required" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/movies/{id}": {
      "get": {
        "summary": "Get a movie by ID",
        "tags": ["Movies"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Movie found" },
          "400": { "description": "Invalid ID format" },
          "404": { "description": "Movie not found" },
          "500": { "description": "Server error" }
        }
      },
      "put": {
        "summary": "Update a movie by ID",
        "tags": ["Movies"],
        "security": [{ "GoogleOAuth": ["profile", "email"] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Movie" }
            }
          }
        },
        "responses": {
          "204": { "description": "Movie updated successfully" },
          "400": { "description": "Validation error or invalid ID" },
          "401": { "description": "Unauthorized - login required" },
          "404": { "description": "Movie not found" },
          "500": { "description": "Server error" }
        }
      },
      "delete": {
        "summary": "Delete a movie by ID",
        "tags": ["Movies"],
        "security": [{ "GoogleOAuth": ["profile", "email"] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Movie deleted successfully" },
          "400": { "description": "Invalid ID format" },
          "401": { "description": "Unauthorized - login required" },
          "404": { "description": "Movie not found" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/tvshows": {
      "get": {
        "summary": "Get all TV shows",
        "tags": ["TV Shows"],
        "responses": {
          "200": { "description": "List of all TV shows" },
          "500": { "description": "Server error" }
        }
      },
      "post": {
        "summary": "Create a new TV show",
        "tags": ["TV Shows"],
        "security": [{ "GoogleOAuth": ["profile", "email"] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Tvshow" }
            }
          }
        },
        "responses": {
          "201": { "description": "TV show created successfully" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized - login required" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/tvshows/{id}": {
      "get": {
        "summary": "Get a TV show by ID",
        "tags": ["TV Shows"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "TV show found" },
          "400": { "description": "Invalid ID format" },
          "404": { "description": "TV show not found" },
          "500": { "description": "Server error" }
        }
      },
      "put": {
        "summary": "Update a TV show by ID",
        "tags": ["TV Shows"],
        "security": [{ "GoogleOAuth": ["profile", "email"] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Tvshow" }
            }
          }
        },
        "responses": {
          "204": { "description": "TV show updated successfully" },
          "400": { "description": "Validation error or invalid ID" },
          "401": { "description": "Unauthorized - login required" },
          "404": { "description": "TV show not found" },
          "500": { "description": "Server error" }
        }
      },
      "delete": {
        "summary": "Delete a TV show by ID",
        "tags": ["TV Shows"],
        "security": [{ "GoogleOAuth": ["profile", "email"] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "TV show deleted successfully" },
          "400": { "description": "Invalid ID format" },
          "401": { "description": "Unauthorized - login required" },
          "404": { "description": "TV show not found" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/auth/google": {
      "get": {
        "summary": "Login with Google",
        "tags": ["Auth"],
        "responses": {
          "302": { "description": "Redirects to Google login page" }
        }
      }
    },
    "/auth/google/callback": {
      "get": {
        "summary": "Google OAuth callback",
        "tags": ["Auth"],
        "responses": {
          "302": { "description": "Redirects to /api-docs on success" }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "summary": "Logout current user",
        "tags": ["Auth"],
        "responses": {
          "302": { "description": "Redirects to home on logout" }
        }
      }
    },
    "/auth/current-user": {
      "get": {
        "summary": "Get currently logged-in user",
        "tags": ["Auth"],
        "responses": {
          "200": { "description": "Returns logged-in user info" },
          "401": { "description": "Not logged in" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "GoogleOAuth": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://accounts.google.com/o/oauth2/auth",
            "tokenUrl": "https://oauth2.googleapis.com/token",
            "scopes": {
              "profile": "Access your profile",
              "email": "Access your email"
            }
          }
        }
      }
    },
    "schemas": {
      "Movie": {
        "type": "object",
        "required": ["title", "genre", "releaseYear", "director", "rating", "duration", "language", "synopsis"],
        "properties": {
          "title": { "type": "string", "example": "Inception" },
          "genre": { "type": "string", "example": "Sci-Fi" },
          "releaseYear": { "type": "integer", "example": 2010 },
          "director": { "type": "string", "example": "Christopher Nolan" },
          "rating": { "type": "number", "minimum": 1, "maximum": 10, "example": 9 },
          "duration": { "type": "integer", "example": 148 },
          "language": { "type": "string", "example": "English" },
          "synopsis": { "type": "string", "example": "A thief who steals corporate secrets through dream-sharing technology." }
        }
      },
      "Tvshow": {
        "type": "object",
        "required": ["title", "genre", "seasons", "episodes", "status", "network", "rating", "language"],
        "properties": {
          "title": { "type": "string", "example": "Breaking Bad" },
          "genre": { "type": "string", "example": "Crime Drama" },
          "seasons": { "type": "integer", "example": 5 },
          "episodes": { "type": "integer", "example": 62 },
          "status": { "type": "string", "enum": ["Ongoing", "Ended"], "example": "Ended" },
          "network": { "type": "string", "example": "AMC" },
          "rating": { "type": "number", "minimum": 1, "maximum": 10, "example": 10 },
          "language": { "type": "string", "example": "English" }
        }
      }
    }
  }
}